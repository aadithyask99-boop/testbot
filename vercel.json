{
  "version": 2,
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Robots-Tag", "value": "index, follow" }
      ]
    }
  ],
  "routes": [
    { "src": "/health",          "dest": "/api/utils.js" },
    { "src": "/robots.txt",      "dest": "/api/utils.js" },
    { "src": "/sitemap.xml",     "dest": "/api/utils.js" },
    { "src": "/ping",            "dest": "/api/utils.js" },
    { "src": "^/dashboard$",       "dest": "/api/dashboard.js" },
    { "src": "^/ui$",              "dest": "/api/dashboard-ui.js" },
    { "src": "^/admin/dashboard$", "dest": "/api/dashboard-ui.js?view=dashboard" },
    { "src": "^/advertiser$",      "dest": "/api/dashboard-ui.js" },
    { "src": "^/advertiser/(?<slug>[^/]+)/overview$", "dest": "/api/dashboard-ui.js?slug=$slug&view=overview" },
    { "src": "^/advertiser/(?<slug>[^/]+)/campaign$", "dest": "/api/dashboard-ui.js?slug=$slug&view=campaign" },
    { "src": "^/publisher$",       "dest": "/api/dashboard-ui.js" },
    { "src": "^/publisher/(?<slug>[^/]+)/overview$",  "dest": "/api/dashboard-ui.js?slug=$slug&view=overview" },
    { "src": "^/publisher/(?<slug>[^/]+)/pages$",  "dest": "/api/dashboard-ui.js?slug=$slug&view=pages" },
    { "src": "^/t/([a-z0-9]+)$", "dest": "/api/click.js?token=$1" },
    { "src": "^/admin/tracklink$",   "dest": "/api/admin.js" },
    { "src": "^/chat/query$",        "dest": "/api/match.js?_route=chat" },
    { "src": "^/chat/ping$",         "dest": "/api/impression.js?_route=chat" },
    { "src": "^/publisher/(?<slug>[^/]+)/chat$", "dest": "/api/dashboard-ui.js?slug=$slug&view=chat" },
    { "src": "/click",           "dest": "/api/click.js" },
    { "src": "/sdk.js",          "dest": "/api/sdk.js" },
    { "src": "/ad",              "dest": "/api/admin.js" },
    { "src": "/admin/reset-stats",    "dest": "/api/admin.js" },
    { "src": "/admin/reindex",        "dest": "/api/admin.js" },
    { "src": "/admin/seed",           "dest": "/api/admin.js" },
    { "src": "/admin/crawl",          "dest": "/api/admin.js" },
    { "src": "/admin/creative-studio",          "dest": "/api/admin.js" },
    { "src": "/admin/campaign/delete", "dest": "/api/admin.js" },
    { "src": "/admin/campaign/pause", "dest": "/api/admin.js" },
    { "src": "/admin/campaign",       "dest": "/api/admin.js" },
    { "src": "/admin",                "dest": "/api/admin.js" },
    { "src": "/match",           "dest": "/api/match.js" },
    { "src": "/precompute",      "dest": "/api/precompute.js" },
    { "src": "/impression",      "dest": "/api/impression.js" },
    { "src": "/articles/(.*)",   "dest": "/api/index.js" },
    { "src": "/",                "dest": "/api/index.js" }
  ]
}
